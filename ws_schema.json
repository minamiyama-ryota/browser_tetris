{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tetris WS Message Schema",
  "description": "Common WebSocket message schema for client-server communication",
  "type": "object",
  "oneOf": [
    { "$ref": "#/definitions/ClientMessage" },
    { "$ref": "#/definitions/ServerMessage" }
  ],
  "definitions": {
    "Common": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "seq": { "type": "integer" },
        "ts": { "type": "integer" },
        "payload": { "type": ["object", "null"] }
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "ClientMessage": {
      "allOf": [
        { "$ref": "#/definitions/Common" },
        {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "type": { "enum": ["join"] },
                "payload": {
                  "type": "object",
                  "properties": { "name": { "type": "string", "minLength": 1 } },
                  "required": ["name"],
                  "additionalProperties": false
                }
              },
              "required": ["payload"]
            },
            {
              "type": "object",
              "properties": {
                "type": { "enum": ["input"] },
                "payload": {
                  "type": "object",
                  "properties": { "action": { "type": "string" } },
                  "required": ["action"],
                  "additionalProperties": false
                }
              },
              "required": ["payload"]
            },
            {
              "type": "object",
              "properties": { "type": { "enum": ["match_ack", "ping", "state_request"] } }
            }
          ]
        }
      ]
    },
    "ServerMessage": {
      "allOf": [
        { "$ref": "#/definitions/Common" },
        {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "type": { "enum": ["match_start"] },
                "payload": {
                  "type": "object",
                  "properties": { "opponent": { "type": "string" } },
                  "required": ["opponent"],
                  "additionalProperties": false
                }
              },
              "required": ["payload"]
            },
            {
              "type": "object",
              "properties": {
                "type": { "enum": ["opponent_input"] },
                "payload": {
                  "type": "object",
                  "properties": { "action": { "type": "string" } },
                  "required": ["action"],
                  "additionalProperties": false
                }
              },
              "required": ["payload"]
            },
            {
              "type": "object",
              "properties": {
                "type": { "enum": ["opponent_left"] }
              }
            },
            {
              "type": "object",
              "properties": {
                "type": { "enum": ["state_update"] },
                "payload": { "type": "object" }
              },
              "required": ["payload"]
            },
            {
              "type": "object",
              "properties": {
                "type": { "enum": ["error"] },
                "payload": {
                  "type": "object",
                  "properties": { "message": { "type": "string" } },
                  "required": ["message"]
                }
              },
              "required": ["payload"]
            }
          ]
        }
      ]
    }
  }
}
